{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/src/*": ["./src/*"],
      "@project/api-client": ["../../packages/api-client/src"],
      "@project/shared-types": ["../../packages/shared-types/src"],
      "@scrimspec/shared-types/hwar": ["../../packages/shared-types/src/hwar"],
      "@scrimspec/db/schema": ["../../packages/db/src/schema"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}