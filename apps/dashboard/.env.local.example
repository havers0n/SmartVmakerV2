# Copy this file to .env.local and fill in your values
# .env.local overrides .env in Next.js.
#
# ── LOCAL DEVELOPMENT ─────────────────────────────────────
# Uncomment for local Supabase Postgres (recommended for dev):
# DRIZZLE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
#
# ── PRODUCTION ────────────────────────────────────────────
# Uncomment ONLY when you need the dashboard to connect to production DB:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.cuwdjemjuszaaxpouprc.supabase.co:5432/postgres

NEXT_PUBLIC_HWAR_ENABLED=true
NEXT_PUBLIC_ENABLE_HWAR_NEW_UI=true
YOUTUBE_API_KEY=your-youtube-api-key
