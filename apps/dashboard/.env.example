# Scrimspec dashboard — safe example only; never commit real credentials.
# Required server-side database connection.  DRIZZLE_DATABASE_URL takes precedence.
DATABASE_URL=postgresql://user:password@localhost:5432/scrimspec
# DRIZZLE_DATABASE_URL=postgresql://user:password@localhost:5432/scrimspec

# Required public Supabase values for dashboard authentication (URL, anon JWT key).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional server-only Supabase client used only by server-side RLS operations.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required only when executing Discovery YouTube collection. Server-only.
# Missing: Discovery search returns a configuration error; no request is sent.
# YOUTUBE_API_KEY=your-youtube-data-api-key

# Optional server-only Gemini enrichment/labeling. Missing: Discovery uses its
# explicit deterministic embedding and "Unknown" labels; it never claims Gemini output.
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# Generation/HWAR only; server-only. Missing provider keys must fail the generation request.
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_GROUP_ID=your-minimax-group-id
# HALU_WEBHOOK_SECRET=long-random-secret
# Development only: permits synthetic MiniMax scenarios when the API is absent.
# It is ignored outside NODE_ENV=development.
# SCRIMSPEC_ALLOW_MOCK_GENERATION=false

# Optional R2 storage integration. Server-only except NEXT_PUBLIC_R2_PUBLIC_BASE_URL.
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=your-access-key-id
# R2_SECRET_ACCESS_KEY=your-secret-access-key
# R2_BUCKET_NAME=your-bucket
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://cdn.example.com

# Optional distributed rate limit; absence intentionally uses local in-memory limiting.
# UPSTASH_REDIS_URL=https://...
# UPSTASH_REDIS_TOKEN=...

# Public UI configuration.
NEXT_PUBLIC_APP_LANG=en
NEXT_PUBLIC_HWAR_ENABLED=false
NEXT_PUBLIC_ENABLE_HWAR_NEW_UI=false

# Never set this to 0 in production. The database package rejects that setting at startup.
# NODE_TLS_REJECT_UNAUTHORIZED=1
