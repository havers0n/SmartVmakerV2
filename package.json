{
  "name": "scrimspec",
  "version": "0.1.0",
  "description": "Scrimspec - Video Analysis & Generation System based on Emotional Architecture (AES)",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@7.33.7",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:packages": "pnpm --filter \"./packages/*\" build --parallel",
    "dev:packages": "pnpm --filter \"./packages/*\" dev --parallel",
    "dev:all": "concurrently --names \"dashboard,ingest,analysis,keyframe,animation\" -c \"bgBlue.bold,bgMagenta.bold,bgCyan.bold,bgGreen.bold,bgYellow.bold\" \"pnpm --filter dashboard dev\" \"pnpm --filter workers dev:ingest\" \"pnpm --filter workers dev:analysis\" \"pnpm --filter workers dev:keyframe\" \"pnpm --filter workers dev:animation\"",
    "start:all": "pm2 start ecosystem.config.cjs",
    "stop:all": "pm2 stop all && pm2 delete all",
    "restart:all": "pm2 restart all",
    "logs": "pm2 logs",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "types:pull": "pnpm --filter db run types:pull"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.6",
    "drizzle-orm": "0.44.7",
    "eslint": "^8.55.0",
    "pm2": "^6.0.13",
    "prettier": "^3.1.0",
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=7.0.0"
  },
  "pnpm": {
    "overrides": {}
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.922.0",
    "@supabase/supabase-js": "^2.76.1"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/havers0n/SmartVmakerV2.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/havers0n/SmartVmakerV2/issues"
  },
  "homepage": "https://github.com/havers0n/SmartVmakerV2#readme"
}
