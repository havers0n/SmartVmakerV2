          ],
          "submitAction": null,
          "onSuccessNav": "step-3"
        },
        {
          "name": "PresetSelection",
          "file": "apps/dashboard/src/app/hwar/create/new/page.tsx",
          "fields": [
            {
              "name": "selectedPresetId",
              "label": "Story Template",
              "type": "card-selection",
              "required": true,
              "validation": "required when source=preset"
            }
          ],
          "submitAction": {
            "name": "listStoryTemplates",
            "file": "apps/dashboard/src/shared/api/actions.ts",
            "kind": "action",
            "endpoint": "/api/actions",
            "actionName": "storyTemplates.list"
          },
          "onSuccessNav": "step-3"
        },
        {
          "name": "TrendSelection",
          "file": "apps/dashboard/src/app/hwar/create/new/page.tsx",
          "fields": [
            {
              "name": "selectedTrendId",
              "label": "Trend",
              "type": "card-selection",
              "required": true,
              "validation": "required when source=trends"
            }
          ],
          "submitAction": {
            "name": "fetchTrends",
            "file": "apps/dashboard/src/app/hwar/create/new/page.tsx",
            "kind": "fetch",
            "endpoint": "/api/analytics/trends",
            "method": "GET"
          },
          "onSuccessNav": "step-3"
        }
      ],
      "states": {
        "loading": true,
        "error": false,
        "empty": true
      },
      "modals": [],
      "outgoing": ["step-3", "/hwar/library/presets"],
      "incoming": ["step-1"]
    },
