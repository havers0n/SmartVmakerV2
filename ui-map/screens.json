{
  "screens": [
    {
      "id": "Home",
      "route": "/",
      "title": "Scrimspec Dashboard",
      "widgets": ["WelcomeCard", "IngestCard", "AnalyzeCard", "SystemOverviewCards"],
      "forms": [],
      "states": {
        "loading": false,
        "error": false,
        "empty": false
      },
      "modals": [],
      "outgoing": ["/ingest", "/analysis"],
      "incoming": []
    },
    {
      "id": "Ingest",
      "route": "/ingest",
      "title": "Ingest",
      "widgets": ["StartIngestForm", "IngestJobsTable"],
      "forms": [
        {
          "name": "StartIngestForm",
          "file": "apps/dashboard/src/features/ingest/StartIngestForm.tsx",
          "fields": [
            {
              "name": "query",
              "label": "Поисковый запрос",
              "type": "text",
              "required": true,
              "validation": "z.string().min(3)"
            },
            {
              "name": "order",
              "label": "Сортировка",
              "type": "select",
              "options": ["date", "rating", "relevance", "viewCount"],
              "required": false,
              "validation": "z.enum(['date', 'rating', 'relevance', 'viewCount']).optional()"
            },
            {
              "name": "videoDuration",
              "label": "Длительность",
              "type": "select",
              "options": ["any", "short", "medium", "long"],
              "required": false,
              "validation": "z.enum(['any', 'short', 'medium', 'long']).optional()"
            },
            {
              "name": "maxResults",
              "label": "Макс. результатов",
              "type": "number",
              "required": false,
              "validation": "z.number().min(1).max(50).optional()"
            },
            {
              "name": "publishedAfter",
              "label": "Опубликовано после",
              "type": "date",
              "required": false,
              "validation": "z.string().optional()"
            },
            {
              "name": "safeSearch",
              "label": "Безопасный поиск",
              "type": "select",
              "options": ["none", "moderate", "strict"],
              "required": false,
              "validation": "z.enum(['none', 'moderate', 'strict']).optional()"
            },
            {
              "name": "videoDefinition",
              "label": "Качество",
              "type": "select",
              "options": ["any", "high", "standard"],
              "required": false,
              "validation": "z.enum(['any', 'high', 'standard']).optional()"
            }
          ],
          "submitAction": {
            "name": "startIngestSearch",
            "file": "apps/dashboard/src/shared/api/actions.ts",
            "kind": "action",
            "endpoint": "/api/actions",
            "actionName": "ingest.startSearch"
          },
          "onSuccessNav": null
        }
      ],
      "states": {
        "loading": true,
        "error": true,
        "empty": false
      },
      "modals": [],
      "outgoing": [],
      "incoming": ["/"]
    },
    {
      "id": "Analysis",
      "route": "/analysis",
      "title": "Analyze Videos",
      "widgets": ["VideoTable", "AnalyzerSelector", "PaginationComponent"],
      "forms": [],
      "states": {
        "loading": true,
        "error": true,
        "empty": true
      },
      "modals": [],
      "outgoing": ["/ingest"],
      "incoming": ["/"]
    },
    {
      "id": "Generation",
      "route": "/generation",
      "title": "Generation & Asset Creation",
      "widgets": ["CreateShortForm", "GenerationStatusTable", "ShortsTable", "AssetsTable"],
      "forms": [
        {
          "name": "CreateShortForm",
          "file": "apps/dashboard/src/app/generation/page.tsx",
          "fields": [
            {
              "name": "templateId",
              "label": "Template ID",
              "type": "text",
              "required": true,
              "validation": "required"
            },
            {
              "name": "provider",
              "label": "Provider",
              "type": "select",
              "options": ["minimax", "hailuo"],
              "required": true,
              "validation": "required"
            }
          ],
          "submitAction": {
            "name": "createShort",
            "file": "apps/dashboard/src/app/generation/page.tsx",
            "kind": "fetch",
            "endpoint": "/api/generation/shorts",
            "method": "POST"
          },
          "onSuccessNav": null
        }
      ],
      "states": {
        "loading": true,
        "error": true,
        "empty": true
      },
      "modals": [],
      "outgoing": [],
      "incoming": ["/"]
    },
    {
