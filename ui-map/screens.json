    {
      "id": "HWAR_Create_New_Step1",
      "route": "/hwar/create/new",
      "step": 1,
      "title": "New Project - Step 1: Project Details",
      "widgets": ["ProjectDetailsForm", "ProgressIndicator"],
      "forms": [
        {
          "name": "ProjectDetailsForm",
          "file": "apps/dashboard/src/app/hwar/create/new/page.tsx",
          "fields": [
            {
              "name": "title",
              "label": "Project Title",
              "type": "text",
              "required": false,
              "validation": "none"
            },
            {
              "name": "ratio",
              "label": "Aspect Ratio",
              "type": "button-group",
              "options": ["16:9", "9:16", "4:3", "3:4"],
              "required": true,
              "validation": "required"
            },
            {
              "name": "lang",
              "label": "Language",
              "type": "select",
              "options": ["none", "ru", "en", "he", "es"],
              "required": true,
              "validation": "required"
            }
          ],
          "submitAction": null,
          "onSuccessNav": "step-2"
        }
      ],
      "states": {
        "loading": false,
        "error": false,
        "empty": false
      },
      "modals": [],
      "outgoing": ["step-2"],
      "incoming": ["/hwar/create"]
    },
    {
