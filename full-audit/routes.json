  "apiRoutes": [
    {
      "path": "/api/actions",
      "file": "apps/dashboard/src/app/api/actions/route.ts",
      "method": "POST",
      "type": "action-runner",
      "description": "Universal action runner endpoint - routes actions to handlers"
    },
    {
      "path": "/api/videos",
      "file": "apps/dashboard/src/app/api/videos/route.ts",
      "method": "GET",
      "type": "data",
      "description": "Fetch ingested videos list"
    },
    {
      "path": "/api/health/db",
      "file": "apps/dashboard/src/app/api/health/db/route.ts",
      "method": "GET",
      "type": "health",
      "description": "Database health check"
    },
    {
      "path": "/api/r2/upload-url",
      "file": "apps/dashboard/src/app/api/r2/upload-url/route.ts",
      "method": "GET",
      "type": "storage",
      "description": "Generate presigned URL for R2 upload"
    },
    {
      "path": "/api/r2/download-url",
      "file": "apps/dashboard/src/app/api/r2/download-url/route.ts",
      "method": "GET",
      "type": "storage",
      "description": "Generate presigned URL for R2 download"
    },
    {
      "path": "/api/analytics/trends",
      "file": "apps/dashboard/src/app/api/analytics/trends/route.ts",
      "method": "GET",
      "type": "analytics",
      "description": "Fetch YouTube video trends for scenario generation"
    },
    {
      "path": "/api/generation/projects/[project_id]",
      "file": "apps/dashboard/src/app/api/generation/projects/[project_id]/route.ts",
      "method": "GET",
      "type": "data",
      "description": "Fetch single generation project by ID"
    },
    {
      "path": "/api/generation/projects/[project_id]/assets",
      "file": "apps/dashboard/src/app/api/generation/projects/[project_id]/assets/route.ts",
      "method": "GET",
      "type": "data",
      "description": "Fetch all assets (keyframes/videos) for a project"
    },
    {
      "path": "/api/webhooks/halu",
      "file": "apps/dashboard/src/app/api/webhooks/halu/route.ts",
      "method": "POST",
      "type": "webhook",
      "description": "Webhook endpoint for MiniMax HALU API callbacks"
    }
  ],
  "actions": [
    {
      "name": "ingest.startSearch",
      "handler": "apps/dashboard/src/app/api/actions/handlers/ingest.ts",
      "description": "Start YouTube video search and ingestion job"
    },
    {
      "name": "analysis.startAnalysis",
      "handler": "apps/dashboard/src/app/api/actions/handlers/analysis.ts",
      "description": "Start video analysis job using Gemini AI"
    },
    {
      "name": "generation.startProject",
      "handler": "apps/dashboard/src/app/api/actions/handlers/generation.ts",
      "description": "Create new generation project with AI scenario generation",
      "integration": "MiniMax-M2 with function calling"
    },
    {
      "name": "generation.generateKeyframes",
      "handler": "apps/dashboard/src/app/api/actions/handlers/generation.ts",
      "description": "Generate keyframes (first/last frames) for selected scenario"
    },
    {
      "name": "generation.startAnimation",
      "handler": "apps/dashboard/src/app/api/actions/handlers/generation.ts",
      "description": "Start animation generation jobs for keyframe pairs"
    },
    {
      "name": "projects.list",
      "handler": "apps/dashboard/src/app/api/actions/handlers/projects.ts",
      "description": "List all generation projects"
    },
    {
      "name": "storyTemplates.create",
      "handler": "apps/dashboard/src/app/api/actions/handlers/story-templates.ts",
      "description": "Create new story template with beats"
    },
    {
      "name": "storyTemplates.list",
      "handler": "apps/dashboard/src/app/api/actions/handlers/story-templates.ts",
      "description": "List all story templates"
    },
    {
      "name": "storyTemplates.getById",
      "handler": "apps/dashboard/src/app/api/actions/handlers/story-templates.ts",
      "description": "Get story template by ID with beats"
    },
    {
      "name": "storyTemplates.update",
      "handler": "apps/dashboard/src/app/api/actions/handlers/story-templates.ts",
      "description": "Update story template"
    },
    {
      "name": "storyTemplates.delete",
      "handler": "apps/dashboard/src/app/api/actions/handlers/story-templates.ts",
      "description": "Delete story template"
    },
    {
      "name": "characters.create",
      "handler": "apps/dashboard/src/app/api/actions/handlers/characters.ts",
      "description": "Create new character"
    },
    {
      "name": "characters.list",
      "handler": "apps/dashboard/src/app/api/actions/handlers/characters.ts",
      "description": "List all characters"
    },
    {
      "name": "characters.getById",
      "handler": "apps/dashboard/src/app/api/actions/handlers/characters.ts",
      "description": "Get character by ID"
    },
    {
      "name": "characters.update",
      "handler": "apps/dashboard/src/app/api/actions/handlers/characters.ts",
      "description": "Update character"
    },
    {
      "name": "characters.delete",
      "handler": "apps/dashboard/src/app/api/actions/handlers/characters.ts",
      "description": "Delete character"
    },
    {
      "name": "models.list",
      "handler": "apps/dashboard/src/app/api/actions/handlers/models.ts",
      "description": "List available AI models by type"
    }
  ]
}
