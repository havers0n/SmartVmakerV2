{
  "routes": [
    {
      "path": "/",
      "file": "apps/dashboard/src/app/page.tsx",
      "name": "Home",
      "type": "page",
      "description": "Main dashboard landing page with quick start cards for Ingest and Analysis"
    },
    {
      "path": "/login",
      "file": "apps/dashboard/src/app/login/page.tsx",
      "name": "Login",
      "type": "auth",
      "description": "User authentication page"
    },
    {
      "path": "/signup",
      "file": "apps/dashboard/src/app/signup/page.tsx",
      "name": "Sign Up",
      "type": "auth",
      "description": "User registration page"
    },
    {
      "path": "/ingest",
      "file": "apps/dashboard/src/app/ingest/page.tsx",
      "name": "Ingest",
      "type": "feature",
      "description": "YouTube video ingestion - search and download videos"
    },
    {
      "path": "/analysis",
      "file": "apps/dashboard/src/app/analysis/page.tsx",
      "name": "Analysis",
      "type": "feature",
      "description": "Video analysis using Gemini AI - emotional architecture analysis"
    },
    {
      "path": "/generation",
      "file": "apps/dashboard/src/app/generation/page.tsx",
      "name": "Generation",
      "type": "feature",
      "description": "Video generation page (legacy/alternative entry point)"
    },
    {
      "path": "/hwar",
      "file": "apps/dashboard/src/app/hwar/page.tsx",
      "name": "HWAR Hub",
      "type": "hub",
      "description": "Main HWAR (Video Generation Factory) hub with 3 main sections",
      "subsections": [
        "Create - New video project generation",
        "Factory - Production pipeline orchestration",
        "Library - Asset and template management"
      ]
    },
    {
      "path": "/hwar/create",
      "file": "apps/dashboard/src/app/hwar/create/page.tsx",
      "name": "HWAR Create - Projects List",
      "type": "list",
      "description": "List of all generation projects with status badges",
      "actions": [
        "View existing projects",
        "Navigate to project details",
        "Create new project"
      ]
    },
    {
      "path": "/hwar/create/new",
      "file": "apps/dashboard/src/app/hwar/create/new/page.tsx",
      "name": "HWAR Create - New Project",
      "type": "form-wizard",
      "description": "3-step wizard for creating new video generation project",
      "steps": [
        "Step 1: Project Details (title, aspect ratio, language, AI models)",
        "Step 2: Content Source (prompt/preset/trends)",
        "Step 3: Review & Generate"
      ],
      "integrations": [
        "MiniMax-M2 API for scenario generation with function calling",
        "Story templates from library",
        "YouTube trends data",
        "AI models selection (text-to-text, text-to-image)"
      ]
    },
    {
      "path": "/hwar/create/[project_id]",
      "file": "apps/dashboard/src/app/hwar/create/[project_id]/page.tsx",
      "name": "HWAR Create - Project Detail",
      "type": "detail",
      "description": "Project detail page with scenario selection and keyframe generation",
      "features": [
        "Scenario selection (multiple AI-generated concepts)",
        "AES scoring visualization",
        "Keyframe generation trigger",
        "Real-time status polling",
        "Keyframe preview (first/last frames per scene)"
      ],
      "polling": {
        "project": "5 seconds when status=processing",
        "assets": "3 seconds when any asset is pending/processing"
      }
    },
    {
      "path": "/hwar/factory",
      "file": "apps/dashboard/src/app/hwar/factory/page.tsx",
      "name": "HWAR Factory - Dashboard",
      "type": "dashboard",
      "description": "Production pipeline orchestration dashboard"
    },
    {
      "path": "/hwar/factory/harvests",
