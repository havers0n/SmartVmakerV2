{
  "name": "@scrimspec/hwar-core",
  "version": "0.0.1",
  "description": "Core domain logic for HWAR (Haverson Web AR)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types/generation": {
      "types": "./dist/types/generation.d.ts",
      "import": "./dist/types/generation.mjs",
      "require": "./dist/types/generation.js"
    },
    "./providers/minimax-video": {
      "types": "./dist/providers/minimax-video.d.ts",
      "import": "./dist/providers/minimax-video.mjs",
      "require": "./dist/providers/minimax-video.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/types/generation.ts src/providers/minimax-video.ts src/image-generation/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/types/generation.ts src/providers/minimax-video.ts src/image-generation/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "lint": "echo 'No linting configured' && exit 0"
  },
  "dependencies": {
    "@scrimspec/db": "workspace:*",
    "@scrimspec/shared-types": "workspace:*",
    "@aec/logger": "workspace:*",
    "@aec/storage-client": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "p-retry": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
