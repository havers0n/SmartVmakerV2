{
  "name": "@scrimspec/db",
  "version": "0.1.0",
  "description": "Database layer with Drizzle ORM for Scrimspec",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./queries": {
      "types": "./dist/queries/index.d.ts",
      "default": "./dist/queries/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests yet' && exit 0",
    "lint": "echo 'No linting configured' && exit 0",
    "format": "echo 'No formatting configured' && exit 0",
    "format:check": "echo 'No formatting configured' && exit 0",
    "migrate": "drizzle-kit migrate",
    "migrate:run": "tsx run-migration.ts",
    "studio": "drizzle-kit studio",
    "generate": "drizzle-kit generate",
    "push": "drizzle-kit push",
    "clean": "rimraf dist",
    "introspect": "tsx introspect-database.ts",
    "schema:pull": "drizzle-kit introspect",
    "types:pull": "tsx scripts/generate-supabase-types.ts",
    "storage:setup": "tsx scripts/setup-storage-buckets.ts",
    "seed": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 tsx src/seed.ts"
  },
  "dependencies": {
    "@scrimspec/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.38.4",
    "dotenv": "^16.3.1",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.3",
    "cross-env": "^10.1.0",
    "supabase": "^1.200.3",
    "tsup": "^8.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}