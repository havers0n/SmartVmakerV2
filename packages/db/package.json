{
  "name": "@scrimspec/db",
  "version": "0.1.0",
  "description": "Database layer with Drizzle ORM for Scrimspec",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./schema": {
      "types": "./dist/src/schema/index.d.ts",
      "default": "./dist/src/schema/index.js"
    },
    "./queries": {
      "types": "./dist/src/queries/index.d.ts",
      "default": "./dist/src/queries/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests yet' && exit 0",
    "lint": "echo 'No linting configured' && exit 0",
    "format": "echo 'No formatting configured' && exit 0",
    "format:check": "echo 'No formatting configured' && exit 0",
    "migrate": "drizzle-kit migrate",
    "migrate:run": "tsx run-migration.ts",
    "studio": "drizzle-kit studio",
    "generate": "drizzle-kit generate:pg",
    "push": "drizzle-kit push:pg",
    "clean": "rm -rf dist",
    "introspect": "tsx introspect-database.ts",
    "schema:pull": "drizzle-kit introspect:pg",
    "types:pull": "tsx scripts/generate-supabase-types.ts"
  },
  "dependencies": {
    "@scrimspec/shared-types": "workspace:*",
    "@supabase/supabase-js": "^2.38.4",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/pg": "^8.11.3",
    "tsx": "^4.7.0",
    "supabase": "^1.200.3"
  }
}
