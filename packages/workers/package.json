{
  "name": "@scrimspec/workers",
  "version": "0.1.0",
  "description": "Background workers for Scrimspec",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "dev:ingest": "cross-env NODE_ENV=development tsx --watch src/ingest-worker.ts",
    "dev:enrich": "cross-env NODE_ENV=development tsx --watch src/enrichment-worker.ts",
    "dev:analysis": "cross-env NODE_ENV=development tsx --watch src/analysis-worker.ts",
    "dev:keyframe": "cross-env NODE_ENV=development tsx --watch src/keyframe-worker.ts",
    "test": "echo 'No tests yet' && exit 0",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aec/logger": "workspace:*",
    "@aec/storage-client": "workspace:*",
    "@scrimspec/db": "workspace:*",
    "@scrimspec/core-domain": "workspace:*",
    "dotenv": "^16.3.1",
    "p-retry": "^6.2.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.10.0"
  }
}
