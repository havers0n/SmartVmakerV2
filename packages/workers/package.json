{
  "name": "@scrimspec/workers",
  "version": "0.1.0",
  "description": "Background workers for Scrimspec",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "type-check": "tsc --noEmit",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "dev:ingest": "cross-env NODE_ENV=development tsx --watch src/ingest-worker.ts",
    "dev:enrich": "cross-env NODE_ENV=development tsx --watch src/enrichment-worker.ts",
    "dev:analysis": "cross-env NODE_ENV=development tsx --watch src/analysis-worker.ts",
    "dev:scenario": "cross-env NODE_ENV=development tsx --watch src/scenario-worker.ts",
    "dev:keyframe": "cross-env NODE_ENV=development tsx --watch src/keyframe-worker.ts",
    "dev:animation": "cross-env NODE_ENV=development tsx --watch src/animation-worker.ts",
    "dev:image": "cross-env NODE_ENV=development tsx --watch src/image-generation/image-worker-entry.ts",
    "dev:image:smoke": "cross-env NODE_ENV=development ALLOW_PAID_IMAGE_SMOKE_TEST=true tsx src/image-generation/smoke-test.ts",
    "dev:cleanup": "tsx --watch src/cleanup-worker.ts",
    "test": "vitest run src/__tests__/scenario-worker.test.ts",
    "test:image": "vitest run src/__tests__/routing-provider-adapter.test.ts src/__tests__/image-normalizer.test.ts src/__tests__/r2-storage-adapter.test.ts src/__tests__/image-worker-runtime.test.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aec/logger": "workspace:*",
    "@aec/storage-client": "workspace:*",
    "@scrimspec/core-domain": "workspace:*",
    "@scrimspec/hwar-core": "workspace:*",
    "@scrimspec/db": "workspace:*",
    "@scrimspec/halu-client": "workspace:*",
    "@scrimspec/shared-types": "workspace:*",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.44.7",
    "p-retry": "^6.2.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
