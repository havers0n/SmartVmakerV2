{
  "name": "@scrimspec/shared-types",
  "version": "0.1.0",
  "description": "Shared TypeScript types and interfaces for Scrimspec",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hwar": {
      "types": "./dist/hwar.d.ts",
      "default": "./dist/hwar.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "echo 'No tests yet' && exit 0",
    "lint": "echo 'No linting configured' && exit 0",
    "format": "echo 'No formatting configured' && exit 0",
    "format:check": "echo 'No formatting configured' && exit 0",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
