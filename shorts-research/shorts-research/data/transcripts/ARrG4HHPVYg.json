[{"text": "В каждой тесле установлена вот такая", "start": 0.04, "duration": 3.72, "source": "captions"}, {"text": "камера. Включается она, когда водитель", "start": 1.839, "duration": 3.92, "source": "captions"}, {"text": "пользуется автопилотом. Камера нужна за", "start": 3.76, "duration": 4.039, "source": "captions"}, {"text": "тем, чтобы следить за водителем. Если он", "start": 5.759, "duration": 3.601, "source": "captions"}, {"text": "перестаёт быть внимательным, ну,", "start": 7.799, "duration": 3.521, "source": "captions"}, {"text": "например, играет в телефон, то автопилот", "start": 9.36, "duration": 3.76, "source": "captions"}, {"text": "останавливает машину. Кстати, раньше", "start": 11.32, "duration": 3.12, "source": "captions"}, {"text": "этой функции не было.", "start": 13.12, "duration": 2.519, "source": "captions"}, {"text": "она заблокировалась.", "start": 14.44, "duration": 3.28, "source": "captions"}, {"text": ">> Китайские водители терпеть это не стали.", "start": 15.639, "duration": 4.001, "source": "captions"}, {"text": "И, как вы думаете, они обманули сложный", "start": 17.72, "duration": 3.96, "source": "captions"}, {"text": "искусственный интеллект от Теслы? Между", "start": 19.64, "duration": 3.68, "source": "captions"}, {"text": "прочим, один из самых продвинутых на", "start": 21.68, "duration": 3.439, "source": "captions"}, {"text": "планете- силиконовые головы с", "start": 23.32, "duration": 3.879, "source": "captions"}, {"text": "Алиэкспресса. Они просто приклеивали их", "start": 25.119, "duration": 4.041, "source": "captions"}, {"text": "к потолку машины, а нейронка на это", "start": 27.199, "duration": 3.641, "source": "captions"}, {"text": "велась. Особенной популярностью", "start": 29.16, "duration": 3.239, "source": "captions"}, {"text": "пользовалась голова Дуэйна Скалы", "start": 30.84, "duration": 3.32, "source": "captions"}, {"text": "Джонсона. Продавцы с Алиэкспресса", "start": 32.399, "duration": 4.401, "source": "captions"}, {"text": "заработали на её продажах почти 180.000", "start": 34.16, "duration": 4.44, "source": "captions"}, {"text": "долларов. После того, как об этом стало", "start": 36.8, "duration": 3.759, "source": "captions"}, {"text": "известно, отдел разработки Tтеesla был в", "start": 38.6, "duration": 3.76, "source": "captions"}, {"text": "ярости, и за сутки они починили", "start": 40.559, "duration": 3.48, "source": "captions"}, {"text": "нейросеть. И водителям теперь", "start": 42.36, "duration": 3.32, "source": "captions"}, {"text": "действительно приходится следить за", "start": 44.039, "duration": 4.16, "source": "captions"}, {"text": "обстановкой.", "start": 45.68, "duration": 2.519, "source": "captions"}]