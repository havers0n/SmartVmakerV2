[{"text": "До 2001 года в Афганистане находились", "start": 0.16, "duration": 4.44, "source": "captions"}, {"text": "два древнейших азиатских памятника", "start": 2.639, "duration": 4.24, "source": "captions"}, {"text": "каменные статуи Будды. Им было минимум", "start": 4.6, "duration": 5.16, "source": "captions"}, {"text": "по 1. Статуи высекли там буддийские", "start": 6.879, "duration": 4.68, "source": "captions"}, {"text": "мастера, когда через дорогу проходил", "start": 9.76, "duration": 3.72, "source": "captions"}, {"text": "Шёлковый путь. Но затем к власти в", "start": 11.559, "duration": 3.96, "source": "captions"}, {"text": "Афганистане пришёл Талибан. Их лидер", "start": 13.48, "duration": 4.2, "source": "captions"}, {"text": "объявил статую идолами, которые порочат", "start": 15.519, "duration": 4.52, "source": "captions"}, {"text": "ислам, и приказал их уничтожить. Мир был", "start": 17.68, "duration": 4.72, "source": "captions"}, {"text": "в ярости. Не трогать статуи просили США", "start": 20.039, "duration": 4.441, "source": "captions"}, {"text": "и Китай. И что интересно, другие", "start": 22.4, "duration": 4.119, "source": "captions"}, {"text": "мусульманские страны. Они понимали, что", "start": 24.48, "duration": 4.24, "source": "captions"}, {"text": "статуи не имеют отношения к исламу, но", "start": 26.519, "duration": 4.401, "source": "captions"}, {"text": "являются важнейшим памятником. Пакистан", "start": 28.72, "duration": 4.32, "source": "captions"}, {"text": "и Эмираты даже отправляли туда делегации", "start": 30.92, "duration": 4.12, "source": "captions"}, {"text": "с требованием не трогать памятники, но", "start": 33.04, "duration": 3.839, "source": "captions"}, {"text": "Талибан отказался и принялся за", "start": 35.04, "duration": 3.839, "source": "captions"}, {"text": "уничтожение. Это оказалось крайне", "start": 36.879, "duration": 3.961, "source": "captions"}, {"text": "сложно. По буддам стреляли из пушек,", "start": 38.879, "duration": 3.961, "source": "captions"}, {"text": "танков и гранатомётов и в скалу даже", "start": 40.84, "duration": 4.16, "source": "captions"}, {"text": "закладывали взрывчатку. Но буддам будто", "start": 42.84, "duration": 4.16, "source": "captions"}, {"text": "бы было похуй. И уничтожить их смогли", "start": 45.0, "duration": 4.039, "source": "captions"}, {"text": "только на двадцать пятый день долбёжки,", "start": 47.0, "duration": 3.96, "source": "captions"}, {"text": "заложив под них суммарно 15 тн", "start": 49.039, "duration": 3.801, "source": "captions"}, {"text": "взрывчатки. Сегодня от буду вообще", "start": 50.96, "duration": 3.88, "source": "captions"}, {"text": "ничего не осталось, только пустые ниши в", "start": 52.84, "duration": 4.16, "source": "captions"}, {"text": "скале.", "start": 54.84, "duration": 2.16, "source": "captions"}]