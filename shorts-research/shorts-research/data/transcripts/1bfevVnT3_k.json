[{"text": "В США пользователи айфонов подверглись", "start": 0.04, "duration": 4.759, "source": "captions"}, {"text": "массовой атаке муувируса.", "start": 2.08, "duration": 4.719, "source": "captions"}, {"text": "Он заставляет iPhone издавать вот такой", "start": 4.799, "duration": 4.76, "source": "captions"}, {"text": "звук.", "start": 6.799, "duration": 4.601, "source": "captions"}, {"text": "Без остановки. В целом, это скорее не", "start": 9.559, "duration": 3.921, "source": "captions"}, {"text": "вирус, а просто баг. Вам присылают", "start": 11.4, "duration": 4.399, "source": "captions"}, {"text": "ссылку, она активирует шортcut, и iPhone", "start": 13.48, "duration": 4.04, "source": "captions"}, {"text": "превращается в телефон, который может", "start": 15.799, "duration": 4.72, "source": "captions"}, {"text": "только издавать звук.", "start": 17.52, "duration": 5.12, "source": "captions"}, {"text": "Shortcut блокирует управление кнопками", "start": 20.519, "duration": 4.481, "source": "captions"}, {"text": "громкости, и люди идут в Apple Store с", "start": 22.64, "duration": 4.479, "source": "captions"}, {"text": "мычащим на полную громкость телефоном.", "start": 25.0, "duration": 3.96, "source": "captions"}, {"text": "На самом деле, пофиксить это довольно", "start": 27.119, "duration": 3.92, "source": "captions"}, {"text": "просто. Нужно нажать тремя пальцами на", "start": 28.96, "duration": 4.04, "source": "captions"}, {"text": "экран, и из режима мычания можно будет", "start": 31.039, "duration": 4.441, "source": "captions"}, {"text": "выйти.", "start": 33.0, "duration": 2.48, "source": "captions"}]