[{"text": "Битва Трампа с бассейном продолжается.", "start": 0.12, "duration": 3.44, "source": "captions"}, {"text": "Чтобы поиздеваться над своим", "start": 2.32, "duration": 2.8, "source": "captions"}, {"text": "президентом, американцы сделали", "start": 3.56, "duration": 3.199, "source": "captions"}, {"text": "специальный сайт. Там они по дням", "start": 5.12, "duration": 3.64, "source": "captions"}, {"text": "отслеживают цвет бассейна и справа", "start": 6.759, "duration": 3.76, "source": "captions"}, {"text": "показали, какой цвет Трамп обещал", "start": 8.76, "duration": 4.08, "source": "captions"}, {"text": "изначально. Немного не сходится. А", "start": 10.519, "duration": 4.441, "source": "captions"}, {"text": "недавно над бассейном запустили дрон. И", "start": 12.84, "duration": 4.48, "source": "captions"}, {"text": "оказалось вот вообще неожиданно. Бассейн", "start": 14.96, "duration": 4.399, "source": "captions"}, {"text": "официально зеленее, чем трава вокруг", "start": 17.32, "duration": 3.959, "source": "captions"}, {"text": "него. Тем временем сам Трамп вообще", "start": 19.359, "duration": 3.84, "source": "captions"}, {"text": "перестал говорить про бассейн. Вопросы", "start": 21.279, "duration": 4.0, "source": "captions"}, {"text": "журналистов он просто игнорирует, а в", "start": 23.199, "duration": 4.08, "source": "captions"}, {"text": "соцсетях про него не пишет вообще.", "start": 25.279, "duration": 3.84, "source": "captions"}, {"text": "Полное молчание. Кстати, количество", "start": 27.279, "duration": 3.601, "source": "captions"}, {"text": "военных вокруг бассейна продолжает", "start": 29.119, "duration": 4.16, "source": "captions"}, {"text": "расти.", "start": 30.88, "duration": 2.399, "source": "captions"}]