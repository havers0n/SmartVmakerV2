[{"text": "Кажется, вы дошутились про то, что акции", "start": 0.08, "duration": 3.839, "source": "captions"}, {"text": "Тетесла постоянно падают. Илон Маск", "start": 1.959, "duration": 3.481, "source": "captions"}, {"text": "официально стал первым в истории", "start": 3.919, "duration": 3.601, "source": "captions"}, {"text": "человечества долларовым триллионером.", "start": 5.44, "duration": 3.68, "source": "captions"}, {"text": "Вот пример сравнения миллиарда и", "start": 7.52, "duration": 3.4, "source": "captions"}, {"text": "триллиона, чтобы понимать, насколько", "start": 9.12, "duration": 3.8, "source": "captions"}, {"text": "большая разница между этими числами.", "start": 10.92, "duration": 4.24, "source": "captions"}, {"text": "Миллион секунд - это 12 дней, миллиард", "start": 12.92, "duration": 4.72, "source": "captions"}, {"text": "секунд - это 32 года, а триллион секунд", "start": 15.16, "duration": 5.08, "source": "captions"}, {"text": "- это 32.000 лет. Вообще за триллион", "start": 17.64, "duration": 4.2, "source": "captions"}, {"text": "долларов в нашем мире можно купить", "start": 20.24, "duration": 3.64, "source": "captions"}, {"text": "довольно много вещей. Ну, например,", "start": 21.84, "duration": 3.92, "source": "captions"}, {"text": "вообще всю недвижимость в Москве,", "start": 23.88, "duration": 3.88, "source": "captions"}, {"text": "включая землю, все квартиры, дома и так", "start": 25.76, "duration": 4.04, "source": "captions"}, {"text": "далее. Это всё оценивается плюс-минус в", "start": 27.76, "duration": 3.919, "source": "captions"}, {"text": "триллион. А самым дорогим объектом в", "start": 29.8, "duration": 5.12, "source": "captions"}, {"text": "мире является МКС. Она стоит 150 млрд. И", "start": 31.679, "duration": 5.761, "source": "captions"}, {"text": "Маск может купить себе 6,5 таких штук.", "start": 34.92, "duration": 4.4, "source": "captions"}, {"text": "Кстати, сам Маск сейчас празднует. А", "start": 37.44, "duration": 3.88, "source": "captions"}, {"text": "акции Тетесла впервые за долгое время не", "start": 39.32, "duration": 4.2, "source": "captions"}, {"text": "упали", "start": 41.32, "duration": 2.2, "source": "captions"}]