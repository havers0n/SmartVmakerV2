[{"text": "В 2001 в США были серьёзные законы по", "start": 0.16, "duration": 4.599, "source": "captions"}, {"text": "поводу ругательств на телевидении.", "start": 2.84, "duration": 3.76, "source": "captions"}, {"text": "Запрещалось использование матов и", "start": 4.759, "duration": 2.761, "source": "captions"}, {"text": "грязных слов.", "start": 6.6, "duration": 2.2, "source": "captions"}, {"text": ">> Блин,", "start": 7.52, "duration": 3.039, "source": "captions"}, {"text": ">> их можно было говорить один раз за", "start": 8.8, "duration": 3.24, "source": "captions"}, {"text": "фильм, причём обязательно в", "start": 10.559, "duration": 3.681, "source": "captions"}, {"text": "эмоциональный момент. Но в этом же году", "start": 12.04, "duration": 3.92, "source": "captions"}, {"text": "создатели мультсериала Южный парк", "start": 14.24, "duration": 3.959, "source": "captions"}, {"text": "выпускают по телеку вот эту имбу, первый", "start": 15.96, "duration": 4.6, "source": "captions"}, {"text": "эпизод пятого сезона. Там слово", "start": 18.199, "duration": 5.4, "source": "captions"}, {"text": "было сказано 162 раза, в среднем один", "start": 20.56, "duration": 5.32, "source": "captions"}, {"text": "раз каждые 8 секунд. Как у создателей", "start": 23.599, "duration": 4.6, "source": "captions"}, {"text": "получилось обойти запреты, они привлекли", "start": 25.88, "duration": 4.639, "source": "captions"}, {"text": "очень крутого юриста. Я бы даже сказал,", "start": 28.199, "duration": 4.08, "source": "captions"}, {"text": "что они позвонили Солу. По закону", "start": 30.519, "duration": 3.761, "source": "captions"}, {"text": "ругаться действительно было нельзя, но", "start": 32.279, "duration": 4.041, "source": "captions"}, {"text": "смеяться над самим запретом, используя", "start": 34.28, "duration": 4.119, "source": "captions"}, {"text": "ругательство, вполне можно. Также юрист", "start": 36.32, "duration": 4.32, "source": "captions"}, {"text": "доказал, если использовать слово", "start": 38.399, "duration": 4.601, "source": "captions"}, {"text": "более пся раз, то оно полностью теряет", "start": 40.64, "duration": 4.68, "source": "captions"}, {"text": "свой смысл и для зрителя превращается", "start": 43.0, "duration": 4.52, "source": "captions"}, {"text": "просто в набор звуков. В итоге цензоры", "start": 45.32, "duration": 4.8, "source": "captions"}, {"text": "согласились, и эпизод со словом", "start": 47.52, "duration": 7.12, "source": "captions"}, {"text": ">> повторённым 162 раза вышел в эфир.", "start": 50.12, "duration": 4.52, "source": "captions"}]