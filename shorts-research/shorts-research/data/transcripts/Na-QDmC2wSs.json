[{"text": "Копам в США начали запрещать", "start": 0.08, "duration": 3.68, "source": "captions"}, {"text": "использовать нейросети. Причина: в", "start": 1.68, "duration": 4.079, "source": "captions"}, {"text": "некоторых отделениях полиции копы брали", "start": 3.76, "duration": 3.8, "source": "captions"}, {"text": "мыльное фото, в основном с камер", "start": 5.759, "duration": 4.001, "source": "captions"}, {"text": "видеонаблюдения, и обскейлили с помощью", "start": 7.56, "duration": 4.32, "source": "captions"}, {"text": "нейросетей. Для отчётности получалось", "start": 9.76, "duration": 3.799, "source": "captions"}, {"text": "очень круто, а потом фотографии", "start": 11.88, "duration": 3.839, "source": "captions"}, {"text": "размещали в ориентировках. Но точность", "start": 13.559, "duration": 4.081, "source": "captions"}, {"text": "таких фотографий с повышенным качеством", "start": 15.719, "duration": 3.961, "source": "captions"}, {"text": "полное Вот простой пример. Берём", "start": 17.64, "duration": 4.32, "source": "captions"}, {"text": "фотографию Нагиева, понижаем ей качество", "start": 19.68, "duration": 4.28, "source": "captions"}, {"text": "и просим нейросеть её дорисовать.", "start": 21.96, "duration": 3.6, "source": "captions"}, {"text": ">> Нельзя отворачиваться от семьи.", "start": 23.96, "duration": 3.559, "source": "captions"}, {"text": ">> Такие повышения качества даже приводили", "start": 25.56, "duration": 3.719, "source": "captions"}, {"text": "к ложным задержаниям. Почему так", "start": 27.519, "duration": 3.6, "source": "captions"}, {"text": "происходит? Нейросеть не повышает", "start": 29.279, "duration": 3.521, "source": "captions"}, {"text": "качество фото в прямом смысле этого", "start": 31.119, "duration": 3.561, "source": "captions"}, {"text": "слова, а сама додумывает внешность", "start": 32.8, "duration": 4.2, "source": "captions"}, {"text": "человека на фото. Не все копы это знали", "start": 34.68, "duration": 4.199, "source": "captions"}, {"text": "и думали, что это какая-то магическая", "start": 37.0, "duration": 3.879, "source": "captions"}, {"text": "кнопка, которая повышает качество, как в", "start": 38.879, "duration": 4.241, "source": "captions"}, {"text": "фильмах.", "start": 40.879, "duration": 2.241, "source": "captions"}]