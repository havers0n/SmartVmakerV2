[{"text": "В Калифорнии полицейские выехали на", "start": 0.04, "duration": 4.08, "source": "captions"}, {"text": "задержание опасного преступника. Мужчина", "start": 1.88, "duration": 3.8, "source": "captions"}, {"text": "заперся в гараже. На вопросы", "start": 4.12, "duration": 3.279, "source": "captions"}, {"text": "переговорщиков он не отвечал. Копы", "start": 5.68, "duration": 3.64, "source": "captions"}, {"text": "решили: \"веннутрь мы заходить не будем.", "start": 7.399, "duration": 4.041, "source": "captions"}, {"text": "Мужчина может сидеть в засаде, поэтому", "start": 9.32, "duration": 4.12, "source": "captions"}, {"text": "просто отправим туда дрон\". Дрон заснял,", "start": 11.44, "duration": 3.76, "source": "captions"}, {"text": "как мужчина сидит в углу гаража, и в", "start": 13.44, "duration": 3.56, "source": "captions"}, {"text": "одной руке у него был нож. Определить", "start": 15.2, "duration": 3.48, "source": "captions"}, {"text": "точно полицейские не могли. Может, он", "start": 17.0, "duration": 3.56, "source": "captions"}, {"text": "потерял сознание? Может, он притворяется", "start": 18.68, "duration": 3.759, "source": "captions"}, {"text": "мёртвым? Или просто ждёт удобного", "start": 20.56, "duration": 3.959, "source": "captions"}, {"text": "момента для нападения. Рисковать жизнью", "start": 22.439, "duration": 3.961, "source": "captions"}, {"text": "никто не хотел, поэтому американские", "start": 24.519, "duration": 4.0, "source": "captions"}, {"text": "копы проявили смекалочку. Они примотали", "start": 26.4, "duration": 4.4, "source": "captions"}, {"text": "к дрону магнит и им вытащили нож из руки", "start": 28.519, "duration": 4.001, "source": "captions"}, {"text": "мужчины. Оказалось, что мужчина был", "start": 30.8, "duration": 3.68, "source": "captions"}, {"text": "сильно пьян и просто спал, поэтому не", "start": 32.52, "duration": 4.879, "source": "captions"}, {"text": "отвечал на вопросы.", "start": 34.48, "duration": 2.919, "source": "captions"}]