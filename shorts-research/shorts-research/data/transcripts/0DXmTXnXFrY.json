[{"text": "Если ваш кот немного непослушный при", "start": 0.12, "duration": 3.4, "source": "captions"}, {"text": "подходе к ветеринару, то вам стоит", "start": 1.88, "duration": 3.6, "source": "captions"}, {"text": "посмотреть вот на эту кису. Сначала он", "start": 3.52, "duration": 4.34, "source": "captions"}, {"text": "вышел из клетки и оценил обстановку.", "start": 5.48, "duration": 4.199, "source": "captions"}, {"text": "[музыка]", "start": 7.86, "duration": 3.859, "source": "captions"}, {"text": ">> Потом он начал вырываться, запрыгнул на", "start": 9.679, "duration": 4.361, "source": "captions"}, {"text": "стол, скинул дорогие препараты. Потом он", "start": 11.719, "duration": 4.761, "source": "captions"}, {"text": "произвёл вычисление и понял: \"Мне очень", "start": 14.04, "duration": 4.239, "source": "captions"}, {"text": "надо под потолок\". Прыжком он выбил", "start": 16.48, "duration": 3.799, "source": "captions"}, {"text": "панель. Вот, кстати, хозяин её потом", "start": 18.279, "duration": 4.481, "source": "captions"}, {"text": "ловит, подтянулся и залез туда и начал", "start": 20.279, "duration": 4.441, "source": "captions"}, {"text": "бегать под потолком. В это время его", "start": 22.76, "duration": 3.8, "source": "captions"}, {"text": "хозяйкиветеринары оказывали первую", "start": 24.72, "duration": 3.879, "source": "captions"}, {"text": "помощь. Кот глубоко её поцарапал, а", "start": 26.56, "duration": 3.879, "source": "captions"}, {"text": "потом потолок не выдержал кота, и он", "start": 28.599, "duration": 4.081, "source": "captions"}, {"text": "просто упал. Его сразу же упаковали.", "start": 30.439, "duration": 3.681, "source": "captions"}, {"text": "Кстати, хозяйке пришлось за всё", "start": 32.68, "duration": 3.44, "source": "captions"}, {"text": "заплатить. И, наверное, кота дома ждал", "start": 34.12, "duration": 4.759, "source": "captions"}, {"text": "серьёзный разговор.", "start": 36.12, "duration": 2.759, "source": "captions"}]