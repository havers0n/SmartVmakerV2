[{"text": "После того, как Трамп проиграл бассейну", "start": 0.08, "duration": 3.52, "source": "captions"}, {"text": "в третий раз, он решил поступить", "start": 2.0, "duration": 3.6, "source": "captions"}, {"text": "по-американски и послал к бассейну", "start": 3.6, "duration": 4.08, "source": "captions"}, {"text": "патрули американских военных. Теперь", "start": 5.6, "duration": 3.88, "source": "captions"}, {"text": "бассейн охраняется минимум двадцатью", "start": 7.68, "duration": 3.72, "source": "captions"}, {"text": "нацгвардейцами. Причина: кто-то", "start": 9.48, "duration": 4.079, "source": "captions"}, {"text": "попытался вылить туда колонию водорослей", "start": 11.4, "duration": 4.359, "source": "captions"}, {"text": "Хлорелла, самых быстро размножающихся", "start": 13.559, "duration": 4.121, "source": "captions"}, {"text": "водорослей. Также люди, которые узнали", "start": 15.759, "duration": 3.721, "source": "captions"}, {"text": "про отслаивающуюся краску, захотели", "start": 17.68, "duration": 3.599, "source": "captions"}, {"text": "забрать себе кусочек, чтобы потом", "start": 19.48, "duration": 3.639, "source": "captions"}, {"text": "продавать её на аукционах, как память о", "start": 21.279, "duration": 3.84, "source": "captions"}, {"text": "позоре Трампа. Трампу это очень не", "start": 23.119, "duration": 3.48, "source": "captions"}, {"text": "нравилось. Также люди снимали", "start": 25.119, "duration": 3.121, "source": "captions"}, {"text": "издевательские тиктоки. Там они", "start": 26.599, "duration": 3.6, "source": "captions"}, {"text": "показывали, как бассейн выглядел до него", "start": 28.24, "duration": 3.92, "source": "captions"}, {"text": "и как он выглядит сейчас. Теперь к", "start": 30.199, "duration": 3.721, "source": "captions"}, {"text": "потраченным на бассейн деньгам, а это", "start": 32.16, "duration": 4.32, "source": "captions"}, {"text": "уже почти 40 млн, прибавилось и зарплата", "start": 33.92, "duration": 5.0, "source": "captions"}, {"text": "охраны суммарно 200.000 долларов в", "start": 36.48, "duration": 4.68, "source": "captions"}, {"text": "месяц.", "start": 38.92, "duration": 2.24, "source": "captions"}]