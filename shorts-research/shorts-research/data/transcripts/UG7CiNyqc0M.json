[{"text": "В 2024 разработчики игры Hell Divers", "start": 0.12, "duration": 4.84, "source": "captions"}, {"text": "предложили игрокам выбрать одну из двух", "start": 3.12, "duration": 3.96, "source": "captions"}, {"text": "планет. На одной по сюжету был склад с", "start": 4.96, "duration": 4.96, "source": "captions"}, {"text": "противотанковыми минами МД-17. Игроки их", "start": 7.08, "duration": 4.92, "source": "captions"}, {"text": "давно ждали, и за выбор этой планеты им", "start": 9.92, "duration": 3.799, "source": "captions"}, {"text": "бы открылась эта мина. А на второй", "start": 12.0, "duration": 3.759, "source": "captions"}, {"text": "планете были просто дети. Их можно было", "start": 13.719, "duration": 4.001, "source": "captions"}, {"text": "спасти и в награду не получить ничего", "start": 15.759, "duration": 3.921, "source": "captions"}, {"text": "особенного, просто немного ресурсов.", "start": 17.72, "duration": 4.04, "source": "captions"}, {"text": "Кажется, выбор очевиден. Но сообщество", "start": 19.68, "duration": 4.28, "source": "captions"}, {"text": "начало кампанию спасти детей. Выбрать", "start": 21.76, "duration": 4.12, "source": "captions"}, {"text": "новое оружие вместо жизни виртуальных", "start": 23.96, "duration": 4.0, "source": "captions"}, {"text": "детей им показалось аморальным. В итоге", "start": 25.88, "duration": 3.719, "source": "captions"}, {"text": "игроки проголосовали за планету с", "start": 27.96, "duration": 3.28, "source": "captions"}, {"text": "детьми, а планета с минами стала", "start": 29.599, "duration": 3.601, "source": "captions"}, {"text": "недоступна. Разработчики такого вообще", "start": 31.24, "duration": 3.8, "source": "captions"}, {"text": "не ожидали и были очень тронуты", "start": 33.2, "duration": 3.76, "source": "captions"}, {"text": "поступкам сообщества настолько, что", "start": 35.04, "duration": 4.199, "source": "captions"}, {"text": "собрали крупную сумму денег и задонатили", "start": 36.96, "duration": 4.2, "source": "captions"}, {"text": "её в фонд помощи детям. За это", "start": 39.239, "duration": 3.84, "source": "captions"}, {"text": "разработчикам прислали оттуда детские", "start": 41.16, "duration": 3.52, "source": "captions"}, {"text": "рисунки с подписью: \"Спасибо,", "start": 43.079, "duration": 3.601, "source": "captions"}, {"text": "хелдайверы\". И разрабы добавили этот", "start": 44.68, "duration": 3.96, "source": "captions"}, {"text": "рисунок как элемент декора в игру. Им", "start": 46.68, "duration": 3.719, "source": "captions"}, {"text": "можно украсить свой корабль. Кстати,", "start": 48.64, "duration": 3.88, "source": "captions"}, {"text": "потом мины игрокам всё-таки добавили и", "start": 50.399, "duration": 5.441, "source": "captions"}, {"text": "выиграли от этой ситуации", "start": 52.52, "duration": 3.32, "source": "captions"}]