[{"text": "камуфляж самый простой способ сделать", "start": 0.08, "duration": 3.839, "source": "captions"}, {"text": "вашего солдата почти невидимым.", "start": 2.12, "duration": 3.28, "source": "captions"}, {"text": "Достаточно подобрать правильную", "start": 3.919, "duration": 3.281, "source": "captions"}, {"text": "расцветку формы, и он буквально", "start": 5.4, "duration": 4.88, "source": "captions"}, {"text": "сливается с местностью. До 2004 года у", "start": 7.2, "duration": 5.24, "source": "captions"}, {"text": "армии США всё было просто. Одна форма", "start": 10.28, "duration": 4.92, "source": "captions"}, {"text": "для леса, а другая для пустыни работала.", "start": 12.44, "duration": 4.759, "source": "captions"}, {"text": "Отлично и претензий не было. Но потом", "start": 15.2, "duration": 4.04, "source": "captions"}, {"text": "американцы решили сэкономить и вместо", "start": 17.199, "duration": 4.121, "source": "captions"}, {"text": "двух форм создать единый универсальный", "start": 19.24, "duration": 4.08, "source": "captions"}, {"text": "камуфляж, который подойдёт одинаково", "start": 21.32, "duration": 4.199, "source": "captions"}, {"text": "хорошо для пустынь городов и лесов. Были", "start": 23.32, "duration": 4.119, "source": "captions"}, {"text": "потрачены миллионы долларов. Годы", "start": 25.519, "duration": 4.041, "source": "captions"}, {"text": "разработки. На выходе получилось ровно", "start": 27.439, "duration": 3.801, "source": "captions"}, {"text": "так, как обычно бывает, когда хочешь", "start": 29.56, "duration": 3.92, "source": "captions"}, {"text": "создать что-то хорошее во всём. Новая", "start": 31.24, "duration": 4.28, "source": "captions"}, {"text": "форма оказалась полным говном и в лесу,", "start": 33.48, "duration": 3.72, "source": "captions"}, {"text": "и в пустыне. Она не просто не", "start": 35.52, "duration": 3.48, "source": "captions"}, {"text": "маскировала солдат, она, наоборот,", "start": 37.2, "duration": 3.4, "source": "captions"}, {"text": "делала их более заметнее на фоне", "start": 39.0, "duration": 3.6, "source": "captions"}, {"text": "местности. Особенно этот камуфляж", "start": 40.6, "duration": 4.24, "source": "captions"}, {"text": "подпортил жизнь солдатам в Афганистане.", "start": 42.6, "duration": 4.2, "source": "captions"}, {"text": "Там они были как на ладони на фоне чего", "start": 44.84, "duration": 4.6, "source": "captions"}, {"text": "угодно и высоко ценили старую пустынку.", "start": 46.8, "duration": 4.56, "source": "captions"}, {"text": "Даже заводили её туда контрабандой.", "start": 49.44, "duration": 4.2, "source": "captions"}, {"text": "Солдаты писали жалобы, но к тому моменту", "start": 51.36, "duration": 4.48, "source": "captions"}, {"text": "новых комплектов произвели уже миллионы,", "start": 53.64, "duration": 3.8, "source": "captions"}, {"text": "так что полностью от них отказались", "start": 55.84, "duration": 4.879, "source": "captions"}, {"text": "только спустя 15 лет.", "start": 57.44, "duration": 3.279, "source": "captions"}]