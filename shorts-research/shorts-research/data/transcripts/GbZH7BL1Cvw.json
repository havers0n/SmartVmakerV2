[{"text": "Самый популярный блогер Таваня 10 лет", "start": 0.08, "duration": 4.08, "source": "captions"}, {"text": "вёл свой канал. В этом ему помогала его", "start": 2.159, "duration": 4.001, "source": "captions"}, {"text": "девушка. Зрители считали их идеальной", "start": 4.16, "duration": 4.359, "source": "captions"}, {"text": "парой, но 2 года назад они расстались, и", "start": 6.16, "duration": 3.8, "source": "captions"}, {"text": "оказалось, что компания, которой", "start": 8.519, "duration": 3.24, "source": "captions"}, {"text": "принадлежал канал, была оформлена на", "start": 9.96, "duration": 4.04, "source": "captions"}, {"text": "мать девушки. За 10 лет канал заработал", "start": 11.759, "duration": 4.721, "source": "captions"}, {"text": "около 3 млн долларов, но самому блогеру", "start": 14.0, "duration": 4.359, "source": "captions"}, {"text": "мать девушки платила копейки, всего", "start": 16.48, "duration": 4.0, "source": "captions"}, {"text": "1.700 долларов в месяц. После их", "start": 18.359, "duration": 4.321, "source": "captions"}, {"text": "расставания мать девушки уволила Энди и", "start": 20.48, "duration": 4.24, "source": "captions"}, {"text": "полностью лишила его доступа к каналу. У", "start": 22.68, "duration": 3.96, "source": "captions"}, {"text": "блогера началась депрессия, но Энди не", "start": 24.72, "duration": 3.719, "source": "captions"}, {"text": "сдался. Он создал новый канал, где", "start": 26.64, "duration": 3.639, "source": "captions"}, {"text": "выпустил видео. Там он рассказал всю", "start": 28.439, "duration": 3.921, "source": "captions"}, {"text": "правду и даже показал доказательства.", "start": 30.279, "duration": 4.12, "source": "captions"}, {"text": "Интернет отреагировал моментально, видео", "start": 32.36, "duration": 4.519, "source": "captions"}, {"text": "стало вирусным, а новый канал Энди за 32", "start": 34.399, "duration": 4.761, "source": "captions"}, {"text": "часа набрал 1 млн подписчиков. Зрители", "start": 36.879, "duration": 3.52, "source": "captions"}, {"text": "писали слова поддержки:", "start": 39.16, "duration": 3.84, "source": "captions"}, {"text": ">> \"Злые люди будут наказаны небесами\"", "start": 40.399, "duration": 4.281, "source": "captions"}, {"text": ">> и отписывались от старого канала.", "start": 43.0, "duration": 3.32, "source": "captions"}, {"text": "Произошло настоящее переселение", "start": 44.68, "duration": 3.68, "source": "captions"}, {"text": "аудитории. В итоге Новый канал обогнал", "start": 46.32, "duration": 3.719, "source": "captions"}, {"text": "по количеству подписчиков старый,", "start": 48.36, "duration": 3.44, "source": "captions"}, {"text": "который юридически принадлежит матери", "start": 50.039, "duration": 3.801, "source": "captions"}, {"text": "его бывшей девушке. Просмотры, кстати, у", "start": 51.8, "duration": 4.0, "source": "captions"}, {"text": "них тоже сильно просели, а сам блогер", "start": 53.84, "duration": 4.0, "source": "captions"}, {"text": "счастлив. Он вернул всех подписчиков и", "start": 55.8, "duration": 5.52, "source": "captions"}, {"text": "теперь может продолжать свою работу.", "start": 57.84, "duration": 3.48, "source": "captions"}]