[{"text": "Недавно в стиме вышла игра, которая", "start": 0.12, "duration": 4.28, "source": "captions"}, {"text": "стала мегапопулярной. Мехамелеон. Это", "start": 1.88, "duration": 4.519, "source": "captions"}, {"text": "модифицированные прятки. Два игрока", "start": 4.4, "duration": 4.159, "source": "captions"}, {"text": "ищут, а остальные должны куда-то залезть", "start": 6.399, "duration": 4.12, "source": "captions"}, {"text": "и пририсовать себя к поверхности, чтобы", "start": 8.559, "duration": 4.04, "source": "captions"}, {"text": "их не было видно. Игрокам такое зашло на", "start": 10.519, "duration": 4.2, "source": "captions"}, {"text": "ура. Казалось бы, зачем и как в этой", "start": 12.599, "duration": 4.44, "source": "captions"}, {"text": "игре можно читерить? Но читеры появились", "start": 14.719, "duration": 4.281, "source": "captions"}, {"text": "откуда не ждали, а они написали очень", "start": 17.039, "duration": 4.08, "source": "captions"}, {"text": "сложную программу. Она анализирует фоны", "start": 19.0, "duration": 3.4, "source": "captions"}, {"text": "в реальном времени, идеально", "start": 21.119, "duration": 3.32, "source": "captions"}, {"text": "перерисовывает его на персонажа. И", "start": 22.4, "duration": 3.92, "source": "captions"}, {"text": "такого спрятанного персонажа почти не", "start": 24.439, "duration": 3.92, "source": "captions"}, {"text": "найти. Но игроки унывать не стали.", "start": 26.32, "duration": 4.16, "source": "captions"}, {"text": "коммьюнитивы игры очень добрая. Они", "start": 28.359, "duration": 4.321, "source": "captions"}, {"text": "начали бороться с читерами. Как именно?", "start": 30.48, "duration": 3.52, "source": "captions"}, {"text": "Они приклеиваются рядом с", "start": 32.68, "duration": 3.559, "source": "captions"}, {"text": "замаскированным читером и рисуют на себе", "start": 34.0, "duration": 4.399, "source": "captions"}, {"text": "яркие стрелки, которые помогают его", "start": 36.239, "duration": 4.64, "source": "captions"}, {"text": "найти. Это длится уже около недели, и", "start": 38.399, "duration": 4.561, "source": "captions"}, {"text": "количество читеров по ощущениям начало", "start": 40.879, "duration": 3.921, "source": "captions"}, {"text": "уменьшаться. А всё благодаря борьбе", "start": 42.96, "duration": 4.2, "source": "captions"}, {"text": "игроков.", "start": 44.8, "duration": 2.36, "source": "captions"}]