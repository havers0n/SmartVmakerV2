[{"text": "Вы наверняка задавались вопросом, что", "start": 0.12, "duration": 4.52, "source": "captions"}, {"text": "полицейские делают с изъятыми нами. В", "start": 2.12, "duration": 4.52, "source": "captions"}, {"text": "большинстве случаев их годами хранят.", "start": 4.64, "duration": 3.879, "source": "captions"}, {"text": "Всё-таки норки зачастую являются", "start": 6.64, "duration": 3.68, "source": "captions"}, {"text": "вечдоком в суде, а процесс может", "start": 8.519, "duration": 3.481, "source": "captions"}, {"text": "тянуться несколько лет. А после", "start": 10.32, "duration": 3.399, "source": "captions"}, {"text": "судебного процесса их сжигают в", "start": 12.0, "duration": 3.48, "source": "captions"}, {"text": "специальных печах или химически", "start": 13.719, "duration": 3.961, "source": "captions"}, {"text": "нейтрализуют, чтобы на выходе получалась", "start": 15.48, "duration": 4.2, "source": "captions"}, {"text": "вот такая жижа, которую нельзя обратно", "start": 17.68, "duration": 4.28, "source": "captions"}, {"text": "перегнать в нарко. Но в Мьянанме полиция", "start": 19.68, "duration": 4.48, "source": "captions"}, {"text": "из утилизации решила устроить шоу. Они", "start": 21.96, "duration": 5.479, "source": "captions"}, {"text": "взяли изъятых на 600 млн долларов. Если", "start": 24.16, "duration": 5.439, "source": "captions"}, {"text": "что, это 1% ВВП их страны.", "start": 27.439, "duration": 4.24, "source": "captions"}, {"text": "рассортировали их по видам и построили", "start": 29.599, "duration": 4.201, "source": "captions"}, {"text": "длинные стеллажи под открытым небом, а", "start": 31.679, "duration": 3.961, "source": "captions"}, {"text": "потом просто подожгли. Всё это было", "start": 33.8, "duration": 3.52, "source": "captions"}, {"text": "сделано во Всемирный день борьбы с", "start": 35.64, "duration": 3.88, "source": "captions"}, {"text": "наркоми. Кстати, интересный факт. В", "start": 37.32, "duration": 5.0, "source": "captions"}, {"text": "среднем 7,5% наркотиков загадочным", "start": 39.52, "duration": 6.879, "source": "captions"}, {"text": "образом исчезают из хранилища вечдоков.", "start": 42.32, "duration": 4.079, "source": "captions"}]