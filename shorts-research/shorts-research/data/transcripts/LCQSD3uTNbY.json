[{"text": "В США выпускник школы решил пошутить.", "start": 0.04, "duration": 3.919, "source": "captions"}, {"text": "Вместо своего детского фото для", "start": 2.32, "duration": 3.36, "source": "captions"}, {"text": "ежегодного альбома он отправил", "start": 3.959, "duration": 3.721, "source": "captions"}, {"text": "фотографию маленького, знаете, кто это?", "start": 5.68, "duration": 4.2, "source": "captions"}, {"text": "Да. Адольфа Гитлера. Подмену никто не", "start": 7.68, "duration": 4.56, "source": "captions"}, {"text": "заметил. Фотография прошла все проверки", "start": 9.88, "duration": 4.36, "source": "captions"}, {"text": "и попала в печать. Ошибку заметили", "start": 12.24, "duration": 4.2, "source": "captions"}, {"text": "совершенно случайно. Один из учеников", "start": 14.24, "duration": 4.119, "source": "captions"}, {"text": "попросил учителя истории расписаться в", "start": 16.44, "duration": 4.36, "source": "captions"}, {"text": "альбоме, и эти глаза он узнал из тысячи.", "start": 18.359, "duration": 4.401, "source": "captions"}, {"text": "После этого школа срочно начала забирать", "start": 20.8, "duration": 3.92, "source": "captions"}, {"text": "все экземпляры обратно. Кстати, в этой", "start": 22.76, "duration": 3.56, "source": "captions"}, {"text": "школе большой процент еврейских", "start": 24.72, "duration": 3.719, "source": "captions"}, {"text": "учеников. Там даже есть факультативы по", "start": 26.32, "duration": 4.039, "source": "captions"}, {"text": "ивриту. Все восприняли ситуацию", "start": 28.439, "duration": 3.881, "source": "captions"}, {"text": "серьёзно. К делу даже подключилась", "start": 30.359, "duration": 4.401, "source": "captions"}, {"text": "полиция. Они быстро нашли шутника, и", "start": 32.32, "duration": 4.52, "source": "captions"}, {"text": "теперь его ждёт отстранение от занятий.", "start": 34.76, "duration": 4.479, "source": "captions"}, {"text": "А его родителям придётся оплатить все", "start": 36.84, "duration": 4.559, "source": "captions"}, {"text": "альбомов с напечатанным Бейби Гитлером.", "start": 39.239, "duration": 4.401, "source": "captions"}, {"text": "Это почти 3.000 долларов. Кстати, сами", "start": 41.399, "duration": 5.16, "source": "captions"}, {"text": "альбомы уничтожат.", "start": 43.64, "duration": 2.919, "source": "captions"}]