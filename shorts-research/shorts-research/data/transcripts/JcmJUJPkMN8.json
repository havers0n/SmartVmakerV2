[{"text": "В ТикТоке на 5 млн залетело ужасное", "start": 0.04, "duration": 4.4, "source": "captions"}, {"text": "видео. На нём повар разделывал говяжьи", "start": 2.24, "duration": 3.8, "source": "captions"}, {"text": "рёбра. При этом он просто кидал их на", "start": 4.44, "duration": 3.84, "source": "captions"}, {"text": "картонку и даже не всегда попадал.", "start": 6.04, "duration": 4.08, "source": "captions"}, {"text": "Временами они падали прямо на грязный", "start": 8.28, "duration": 4.08, "source": "captions"}, {"text": "асфальт. Автор видеоадреса ресторана не", "start": 10.12, "duration": 4.2, "source": "captions"}, {"text": "оставил, поэтому пользователям Редита", "start": 12.36, "duration": 3.72, "source": "captions"}, {"text": "пришлось брать всё в свои руки. По", "start": 14.32, "duration": 3.92, "source": "captions"}, {"text": "сливной трубе, освещению и форме крыши", "start": 16.08, "duration": 3.959, "source": "captions"}, {"text": "они вычислили заведение. Это был", "start": 18.24, "duration": 3.68, "source": "captions"}, {"text": "ресторан Fallof в Калифорнии. Они", "start": 20.039, "duration": 3.801, "source": "captions"}, {"text": "завалили санитарную службу жалобами на", "start": 21.92, "duration": 3.56, "source": "captions"}, {"text": "ресторан, и туда реально приехали", "start": 23.84, "duration": 3.519, "source": "captions"}, {"text": "инспекторы с проверкой. Оказалось, что", "start": 25.48, "duration": 3.719, "source": "captions"}, {"text": "проблем в ресторане очень много. На", "start": 27.359, "duration": 3.561, "source": "captions"}, {"text": "кухне нашли тараканов, продукты там", "start": 29.199, "duration": 3.921, "source": "captions"}, {"text": "хранили неправильно и очень плохо мыли", "start": 30.92, "duration": 4.639, "source": "captions"}, {"text": "посуду.", "start": 33.12, "duration": 2.439, "source": "captions"}]