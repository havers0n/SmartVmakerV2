[{"text": "Сейчас будет грустно. В ТикТоке был", "start": 0.16, "duration": 3.799, "source": "captions"}, {"text": "найден аккаунт девушки, которая доведёт", "start": 2.12, "duration": 4.08, "source": "captions"}, {"text": "до нервного срыва любого человека. Пару", "start": 3.959, "duration": 4.281, "source": "captions"}, {"text": "месяцев назад она запостила вот это.", "start": 6.2, "duration": 4.319, "source": "captions"}, {"text": "Очень крутая тачка. Но через 2 недели", "start": 8.24, "duration": 4.559, "source": "captions"}, {"text": "она выложила вот эту фотографию. Машина", "start": 10.519, "duration": 4.2, "source": "captions"}, {"text": "полностью разбита. Хотя бы с девушкой", "start": 12.799, "duration": 3.681, "source": "captions"}, {"text": "всё в порядке. Через пару недель она", "start": 14.719, "duration": 3.961, "source": "captions"}, {"text": "выкладывает новый пост. Жених купил ей", "start": 16.48, "duration": 4.44, "source": "captions"}, {"text": "Audi. Проходит 2 недели. И да, эта", "start": 18.68, "duration": 4.56, "source": "captions"}, {"text": "машина тоже разбита. Ещё один пост через", "start": 20.92, "duration": 4.64, "source": "captions"}, {"text": "неделю. Ей снова купили BMW. И вы", "start": 23.24, "duration": 4.16, "source": "captions"}, {"text": "правильно догадались. Машина снова", "start": 25.56, "duration": 3.879, "source": "captions"}, {"text": "полностью разбита. Но с девушкой всё в", "start": 27.4, "duration": 4.039, "source": "captions"}, {"text": "порядке. Кстати, сейчас жених всё-таки", "start": 29.439, "duration": 4.401, "source": "captions"}, {"text": "купил ей Теслу. Вот машинка. После этого", "start": 31.439, "duration": 4.761, "source": "captions"}, {"text": "девушка уже ничего не постила. Целых 4", "start": 33.84, "duration": 4.28, "source": "captions"}, {"text": "дня на момент выхода этого ролика. Так", "start": 36.2, "duration": 5.32, "source": "captions"}, {"text": "что ждём её новых видосов.", "start": 38.12, "duration": 3.4, "source": "captions"}]