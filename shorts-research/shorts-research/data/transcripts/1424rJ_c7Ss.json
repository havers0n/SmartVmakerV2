[{"text": "Трубочки, трубочки, трубочки, трубочки,", "start": 0.08, "duration": 3.96, "source": "captions"}, {"text": "трубочки, трубочки, трубочки. Раньше", "start": 2.2, "duration": 3.8, "source": "captions"}, {"text": "трубочки были из пластика. Это был", "start": 4.04, "duration": 3.759, "source": "captions"}, {"text": "идеал. Они не плавились от тёплых", "start": 6.0, "duration": 4.28, "source": "captions"}, {"text": "напитков и не имели своего вкуса. Такие", "start": 7.799, "duration": 5.081, "source": "captions"}, {"text": "трубочки были повсюду. Но в 2015 в", "start": 10.28, "duration": 4.439, "source": "captions"}, {"text": "интернет попало видео, где у черепахи в", "start": 12.88, "duration": 3.84, "source": "captions"}, {"text": "носу застряла пластиковая трубочка. И", "start": 14.719, "duration": 4.201, "source": "captions"}, {"text": "мир решил, надо от них отказываться и", "start": 16.72, "duration": 4.16, "source": "captions"}, {"text": "заменять на что-то новое. Так появились", "start": 18.92, "duration": 4.16, "source": "captions"}, {"text": "бумажные трубочки. Это буквально худшее", "start": 20.88, "duration": 4.399, "source": "captions"}, {"text": "изобретение человечества. Они размекают", "start": 23.08, "duration": 4.24, "source": "captions"}, {"text": "и придают любому напитку отвратительный", "start": 25.279, "duration": 4.08, "source": "captions"}, {"text": "вкус бумаги. При этом бумажные трубочки", "start": 27.32, "duration": 3.48, "source": "captions"}, {"text": "дорого стоят, но люди решили", "start": 29.359, "duration": 2.961, "source": "captions"}, {"text": "адаптироваться. Так появились", "start": 30.8, "duration": 3.52, "source": "captions"}, {"text": "многоразовые стеклянные и металлические", "start": 32.32, "duration": 4.32, "source": "captions"}, {"text": "трубочки. Идея крайне плохая. Тысячи", "start": 34.32, "duration": 4.559, "source": "captions"}, {"text": "выбитых металлическими трубками зубов, а", "start": 36.64, "duration": 4.079, "source": "captions"}, {"text": "также один летальный случай, когда", "start": 38.879, "duration": 3.601, "source": "captions"}, {"text": "человек в машине случайно раскусил", "start": 40.719, "duration": 3.84, "source": "captions"}, {"text": "стеклянную трубочку. Лучше не покупайте", "start": 42.48, "duration": 3.96, "source": "captions"}, {"text": "их. В итоге всё вернулось откуда и", "start": 44.559, "duration": 3.721, "source": "captions"}, {"text": "начиналось. Везде снова появляются", "start": 46.44, "duration": 4.639, "source": "captions"}, {"text": "пластиковые трубки.", "start": 48.28, "duration": 2.799, "source": "captions"}]