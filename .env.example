# ============================================================================
# SCRIMSPEC ENVIRONMENT VARIABLES
# ============================================================================

# Copy this file to .env and fill in your values

# ============================================================================
# MiniMax API
# ============================================================================
MINIMAX_API_KEY=sk-your-minimax-api-key-here
PUBLIC_BASE_URL=http://localhost:8000
# In production: https://your-domain.com

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8000
NODE_ENV=development
# Options: development, production, test

# CORS configuration (comma-separated origins)
# Leave empty for all origins (development only!)
CORS_ORIGIN=http://localhost:3000,http://localhost:8000

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection (used by Drizzle ORM)
DATABASE_URL=postgresql://user:password@localhost:5432/scrimspec

# Supabase configuration (optional)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
# Options: trace, debug, info, warn, error, fatal

# ============================================================================
# FEATURES
# ============================================================================

# HelloWhoAreYou feature flag
NEXT_PUBLIC_HWAR_ENABLED=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# File upload settings
MAX_UPLOAD_SIZE_MB=100

# ============================================================================
# PYTHON TOOLS (for yt-orchestrator)
# ============================================================================
YOUTUBE_API_KEY=your-youtube-api-key
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# DEPLOYMENT (production only)
# ============================================================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# S3_BUCKET=scrimspec-videos

# Sentry monitoring
# SENTRY_DSN=https://your-sentry-dsn

# Analytics
# MIXPANEL_TOKEN=your-token
# POSTHOG_KEY=your-key


# ============================================================================

# ============================================================================
